# ---------- MySQL ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=donation_social

# ---------- Grok (xAI) API keys - ONE PER LANGGRAPH, as requested ----------
# 1) Priority ranking graph (recency + low-impression boosting)
GROK_API_KEY_PRIORITY=xai-xxxxxxxxxxxxxxxxxxxxxxxx
# 2) Smart Matching graph (hashtag <-> interest semantic matching)
GROK_API_KEY_MATCHING=xai-xxxxxxxxxxxxxxxxxxxxxxxx
# 3) Scam Alert graph (repeated-report scam analysis)
GROK_API_KEY_SCAM=xai-xxxxxxxxxxxxxxxxxxxxxxxx

GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4-fast

# ---------- Gemini (chatbot only, per spec) ----------
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ---------- App config ----------
UPLOAD_DIR=uploads
SCAM_REPORT_THRESHOLD=3
FOOD_POST_LIFETIME_HOURS=24
